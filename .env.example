# Use 64 hex characters (32 bytes) or any passphrase (hashed with SHA-256).
# COMPLISURE_ENCRYPTION_KEY=

# Per-tenant Qdrant collections: complisure_ca_tasks_<hash>, etc. Set false for legacy single shared collections.
# COMPLISURE_MULTI_TENANT_QDRANT=true
